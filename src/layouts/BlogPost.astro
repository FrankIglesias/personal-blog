---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags, codesandbox } = post.data;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Francisco Iglesias',
    url: 'https://blog.franciscoiglesias.me',
  },
  url: canonicalURL,
  keywords: tags.join(', '),
};
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article>
    <header class="post-header">
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        <div class="tags">
          {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </div>
      <h1>{title}</h1>
      <p class="description">{description}</p>
    </header>

    <hr />

    <div class="prose">
      <slot />
    </div>

    {
      codesandbox && (
        <div class="codesandbox-wrapper">
          <iframe
            src={codesandbox}
            style="width:100%; height:500px; border:0; border-radius:6px; overflow:hidden;"
            title="CodeSandbox demo"
            allow="accelerometer; ambient-light-sensor; camera; encrypted-media; geolocation; gyroscope; hid; microphone; midi; payment; usb; vr; xr-spatial-tracking"
            sandbox="allow-forms allow-modals allow-popups allow-presentation allow-same-origin allow-scripts"
            loading="lazy"
          />
        </div>
      )
    }

    <footer class="post-footer">
      <a href="/" class="back-link">← All posts</a>
    </footer>
  </article>
</BaseLayout>

<style>
  article {
    max-width: 100%;
  }

  .post-header {
    margin-bottom: var(--spacing-lg);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
    flex-wrap: wrap;
  }

  time {
    color: var(--color-muted);
    font-size: 0.875rem;
  }

  .tags {
    display: flex;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.2em 0.6em;
    background-color: var(--color-tag-bg);
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-body);
  }

  h1 {
    font-size: clamp(2.5rem, 10vw, 3.5rem);
    margin-bottom: var(--spacing-md);
  }

  .description {
    font-size: 1.1rem;
    color: var(--color-muted);
    margin-bottom: 0;
  }

  .codesandbox-wrapper {
    margin: var(--spacing-xl) 0;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    overflow: hidden;
  }

  .post-footer {
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-lg);
    border-top: 0.5px solid var(--color-border);
  }

  .back-link {
    font-size: 0.875rem;
    color: var(--color-muted);
    border-bottom: none;
  }

  .back-link:hover {
    color: var(--color-text);
    border-bottom: none;
  }
</style>

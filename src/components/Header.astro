---
const currentPath = Astro.url.pathname;

const nav = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
];
---

<header>
  <div class="header-inner">
    <a href="/" class="brand" aria-label="Home">
      <img src="/favicon.png" alt="</ >" width="32" height="32" />
    </a>
    <nav aria-label="Main navigation">
      <ul>
        {
          nav.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={[{ active: currentPath === href || (href === '/blog' && currentPath.startsWith('/blog')) }]}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  header {
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    background: var(--color-bg);
    z-index: 100;
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--spacing-md) var(--spacing-lg);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    border-bottom: none;
    display: flex;
    align-items: center;
    opacity: 0.85;
    transition: opacity 0.15s;
  }

  .brand:hover {
    opacity: 1;
    border-bottom: none;
  }

  .brand img {
    display: block;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: var(--spacing-lg);
  }

  nav a {
    font-size: 0.875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    border-bottom: none;
    transition: color 0.15s;
  }

  nav a:hover,
  nav a.active {
    color: var(--color-text);
  }

  nav a.active {
    border-bottom: 1px solid var(--color-text);
  }
</style>
